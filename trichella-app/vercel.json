{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/analyse.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/upload-drive.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
