# OpenAI — used for scalp analysis when set (takes precedence over Gemini). Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Optional: OpenAI model (default gpt-4o for vision)
# OPENAI_MODEL=gpt-4o

# Gemini — used when OPENAI_API_KEY is not set. Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# Optional: backend port (default 3001)
# PORT=3001
